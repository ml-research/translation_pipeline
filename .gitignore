# Ignore everything by default, then whitelist only translation/validation code.
*

# Allow directory traversal so nested whitelist rules work.
!*/

# Keep local one-off repair scripts out of the repo.
local_scripts/

# Keep this file.
!.gitignore

# Keep top-level translation/validation project files.
!README.md
!pyproject.toml
!uv.lock
!translate_datatrove.py
!validate_datatrove_output.py

# Keep the refactored translation pipeline package.
!translation_pipeline/
!translation_pipeline/**

# Still ignore Python cache artifacts even inside whitelisted paths.
__pycache__/
*.py[oc]
